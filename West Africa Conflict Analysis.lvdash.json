    {
      "name": "62a9cc52",
      "displayName": "hotspot top20",
      "queryLines": [
        "SELECT\n",
        "    country,\n",
        "    state_province,\n",
        "    total_incidents,\n",
        "    total_deaths,\n",
        "    civilian_deaths\n",
        "FROM hotspot_locations\n",
        "WHERE state_province != 'Unknown'\n",
        "ORDER BY total_incidents DESC\n",
        "LIMIT 20"
      ],
      "catalog": "west_africa_conflict",
      "schema": "gold"
    }
  ],
